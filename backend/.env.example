# Soft-Cases Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# === REQUIRED ===

# PostgreSQL connection string
# Local: postgresql://postgres:postgres@localhost:5432/soft_cases
# Railway: auto-provided as DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soft_cases

# HS256 JWT secret — any long random string (min 32 chars)
AUTH_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Perplexity API key — get at https://www.perplexity.ai/settings/api
# Pricing: ~$5/month (pay-per-token, sonar-pro model recommended)
PERPLEXITY_API_KEY=pplx-

# === OPTIONAL ===

# Semantic Scholar partner API key — raises rate limit from 1 req/sec to 10 req/sec
# Get at: https://www.semanticscholar.org/product/api — free, no approval needed
# Without this key, discovery runs will be slower but will still work
SEMANTIC_SCHOLAR_API_KEY=

# arXiv: NO KEY REQUIRED — uses export.arxiv.org endpoint freely

# === DEFAULTS (change if needed) ===

# Maximum discovery runs per day
DAILY_RUN_LIMIT=10

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Environment
ENV=development

# Soft-Cases Backend — Environment Variables
# Local: copy to .env and fill in.
# Railway: set each variable in the service's Variables tab. Never commit .env.

# === REQUIRED ===

# PostgreSQL connection string
# Railway: auto-injected as DATABASE_URL when you attach the PostgreSQL plugin
# Local: postgresql://postgres:postgres@localhost:5432/soft_cases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soft_cases

# HS256 JWT secret — any long random string (min 32 chars)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Perplexity API key — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-

# === OPTIONAL ===

# Semantic Scholar partner API key — raises rate limit from 1/sec to 10/sec
# Get free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAI API key for novice topic -> cluster generation
# Optional if you only use manual JSON flow
OPENAI_API_KEY=

# OpenAI model for cluster generation
OPENAI_MODEL=gpt-5.4-nano

# arXiv: no key required

# === DEFAULTS (override in Railway Variables tab) ===

# Maximum discovery runs per day
DAILY_RUN_LIMIT=10

# CORS origins — set to your Railway frontend URL in production
# Example: https://soft-cases-frontend-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3005

# Environment — set to "production" on Railway
ENV=development

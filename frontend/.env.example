# Soft-Cases Frontend — Environment Variables
# Copy to .env.local and fill in.

# Backend API URL (server-side SSR calls)
INTERNAL_API_URL=http://localhost:8004

# Backend API URL (client-side browser calls)
NEXT_PUBLIC_API_URL=http://localhost:8004

# Shell nav bar URL (optional — omit for standalone)
NEXT_PUBLIC_SHELL_DASHBOARD_URL=https://shell-production-3509.up.railway.app/dashboard

# Shell handoff: value-lab must have SOFT_CASES_URL pointing at this frontend origin
# (e.g. https://soft-cases-frontend-production.up.railway.app)
